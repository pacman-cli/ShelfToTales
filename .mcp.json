{
  "mcpServers": {
    "serena": {
      "command": "/opt/anaconda3/bin/serena",
      "args": ["start-mcp-server", "--transport", "stdio", "--context", "claude-code", "--project-from-cwd"],
      "env": {}
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {}
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "env": {}
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"],
      "env": {}
    }
  }
}
